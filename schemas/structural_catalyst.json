{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "catalyx/schemas/structural_catalyst.json",
  "schema_version": "1.2",
  "title": "StructuralCatalyst",
  "description": "A secular, ongoing macro trend (not a discrete event). Validated by persistent indicators, not a single headline. Decays slowly over months/years.",
  "type": "object",
  "required": ["id", "schema_version", "type", "title", "description", "created_at", "created_by", "onset_period", "catalyst_type", "indicators", "deactivation_conditions", "intensity", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^struct_[a-z0-9_]+$",
      "description": "Format: struct_keyword_keyword. Human-readable slug."
    },
    "schema_version": { "type": "string", "const": "1.2" },
    "type": { "type": "string", "const": "structural" },
    "title": { "type": "string" },
    "description": {
      "type": "string",
      "minLength": 50,
      "description": "Full description of the trend, its mechanism, and why it is structural (not episodic)."
    },
    "created_at": { "type": "string", "format": "date-time" },
    "created_by": {
      "type": "string",
      "enum": ["user", "system"],
      "description": "Structural catalysts are typically user-defined. System may propose based on flow anomaly detection."
    },
    "onset_period": {
      "type": "string",
      "pattern": "^[0-9]{4}-Q[1-4]$",
      "description": "Quarter when the structural trend became clearly established. Format: YYYY-QN."
    },
    "onset_evidence": {
      "type": "string",
      "description": "Specific data or event that marks the onset. Must be falsifiable/cited."
    },
    "catalyst_type": {
      "type": "string",
      "enum": [
        "monetary_policy",
        "fiscal_policy",
        "geopolitical",
        "commodity_supply",
        "regulatory",
        "institutional_flow",
        "macro_data_release",
        "technology_adoption",
        "demographic",
        "climate_transition",
        "sanctions_trade"
      ]
    },
    "catalyst_subtype": { "type": "string" },
    "geography": {
      "type": "array",
      "items": { "type": "string" }
    },
    "thematic_tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "user_rank": {
      "type": ["integer", "null"],
      "minimum": 1,
      "description": "User-assigned priority. 1=highest conviction. null=unranked (multiplier 1.0)."
    },
    "user_notes": { "type": "string" },
    "intensity": {
      "type": "object",
      "required": ["current_score", "last_updated"],
      "properties": {
        "current_score": {
          "type": "number",
          "minimum": 10,
          "maximum": 95,
          "description": "COMPUTED from indicator semaphores. Formula in scoring_weights.yaml: round(indicator_avg × trend_factor, 1). Do NOT assign manually after initial bootstrap. Run /catalyx-update to recompute after any indicator change."
        },
        "computation_method": {
          "type": "string",
          "enum": ["bootstrap", "computed", "user_override"],
          "default": "bootstrap",
          "description": "bootstrap = initial manual estimate at creation. computed = derived from indicator semaphores (use after first indicator update). user_override = manual override with documented justification."
        },
        "computation_note": {
          "type": ["string", "null"],
          "description": "Required when computation_method = user_override. Explain why formula result was overridden."
        },
        "last_updated": { "type": "string", "format": "date" },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["period", "score"],
            "properties": {
              "period": { "type": "string", "pattern": "^[0-9]{4}-Q[1-4]$" },
              "score": { "type": "number", "minimum": 10, "maximum": 95 },
              "note": { "type": "string" },
              "computation_method": {
                "type": "string",
                "enum": ["bootstrap", "computed", "user_override"]
              }
            }
          }
        }
      }
    },
    "narrative_maturity": {
      "type": "string",
      "enum": ["ignored", "emerging", "mainstream", "crowded", "exhausted"],
      "description": "Categorical narrative saturation level. See scoring_weights.yaml narrative_maturity_levels for anchored criteria. More stable than a 0-100 score across LLM sessions."
    },
    "indicators": {
      "type": "array",
      "minItems": 1,
      "description": "Observable data series that confirm the trend is active and measure its intensity.",
      "items": {
        "type": "object",
        "required": ["id", "name", "source", "check_frequency", "direction", "threshold_strong", "threshold_weak"],
        "properties": {
          "id": { "type": "string", "pattern": "^ind_[0-9]{2}$" },
          "name": { "type": "string" },
          "source": { "type": "string" },
          "source_url_template": { "type": "string" },
          "check_frequency": { "type": "string", "enum": ["daily", "weekly", "monthly", "quarterly"] },
          "current_value": { "type": ["number", "null"] },
          "unit": { "type": "string" },
          "direction": {
            "type": "string",
            "enum": ["higher_is_stronger", "lower_is_stronger"],
            "description": "Which direction of this indicator confirms the structural trend."
          },
          "threshold_strong": { "type": "number", "description": "Value above/below which trend is confirmed as strong." },
          "threshold_weak": { "type": "number", "description": "Value above/below which trend is considered weakening." },
          "last_value": { "type": ["number", "null"] },
          "last_date": { "type": ["string", "null"], "format": "date" }
        }
      }
    },
    "deactivation_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "condition", "action"],
        "properties": {
          "id": { "type": "string", "pattern": "^deact_[0-9]{2}$" },
          "condition": { "type": "string", "description": "Specific, measurable. Not vague." },
          "action": {
            "type": "string",
            "enum": ["downgrade_to_weak", "full_deactivation", "review_required"]
          }
        }
      }
    },
    "linked_event_catalyst_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Event catalysts that are acceleration events within this structural trend."
    },
    "linked_structural_catalyst_ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Other structural catalysts that share thematic overlap or create compounding demand on the same sectors."
    },
    "status": {
      "type": "string",
      "enum": ["active", "weakening", "deactivated", "archived"]
    },
    "status_last_reviewed": { "type": "string", "format": "date" }
  },
  "additionalProperties": false
}
