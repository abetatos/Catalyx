{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "catalyx/schemas/thesis.json",
  "schema_version": "1.2",
  "_changelog": "v1.2: added entry_missed to status enum (expired entry windows); added correlation_check to metadata (shared-catalyst allocation check, step 2.5 of /catalyx-thesis draft).",
  "title": "Thesis",
  "description": "A structured, falsifiable investment thesis. Every field must be specific and measurable — vague theses are rejected by ThesisValidator.",
  "type": "object",
  "required": ["id", "schema_version", "version", "created_at", "status", "catalyst", "sector", "vehicle", "entry", "assumptions", "invalidation_conditions", "time_horizon", "tax", "metadata"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^thesis_[0-9]{8}_[a-z0-9_]+$",
      "description": "Format: thesis_YYYYMMDD_sectorid_keyword"
    },
    "schema_version": { "type": "string", "const": "1.2" },
    "version": { "type": "integer", "minimum": 1, "description": "Increments on material edits to open thesis." },
    "created_at": { "type": "string", "format": "date-time" },
    "last_modified_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["draft", "entry_missed", "open", "exited_by_invalidation", "exited_by_time", "exited_by_conviction_loss", "closed"],
      "description": "entry_missed: entry_window_closes passed without the thesis moving to open. Thesis remains valid but entry conditions must be re-evaluated before re-activating."
    },
    "catalyst": {
      "type": "object",
      "required": ["catalyst_event_id", "catalyst_summary", "catalyst_type", "novelty_assessment"],
      "properties": {
        "catalyst_event_id": { "type": "string", "description": "ID of CatalystEvent or StructuralCatalyst driving this thesis." },
        "catalyst_type": { "type": "string", "enum": ["event", "structural"] },
        "catalyst_summary": { "type": "string" },
        "novelty_assessment": { "type": "string", "description": "Is this already priced in? What is the market's current expectation?" }
      }
    },
    "sector": {
      "type": "object",
      "required": ["sector_id", "sector_snapshot_id", "rationale"],
      "properties": {
        "sector_id": { "type": "string" },
        "sector_snapshot_id": { "type": "string" },
        "rationale": {
          "type": "string",
          "minLength": 50,
          "description": "Why this specific granular sector and not adjacent sectors. Must explain the differentiation."
        }
      }
    },
    "vehicle": {
      "type": "object",
      "required": ["primary_etf", "currency", "currency_hedge"],
      "properties": {
        "primary_etf": { "type": "string" },
        "currency": { "type": "string" },
        "currency_hedge": { "type": "boolean" },
        "currency_risk_note": { "type": "string" },
        "alternative_etfs": { "type": "array", "items": { "type": "string" } },
        "vehicle_selection_rationale": { "type": "string" }
      }
    },
    "entry": {
      "type": "object",
      "required": ["trigger_type", "trigger_description", "sizing_method", "conviction_tier", "position_size_pct_portfolio"],
      "properties": {
        "trigger_type": {
          "type": "string",
          "enum": ["price_action", "flow_confirmation", "calendar_event", "price_and_flow", "manual"]
        },
        "trigger_description": { "type": "string" },
        "entry_price_limit": { "type": ["number", "null"] },
        "entry_window_closes": { "type": ["string", "null"], "format": "date" },
        "sizing_method": { "type": "string", "enum": ["conviction_tier", "kelly_fraction", "fixed_pct"] },
        "conviction_tier": { "type": "integer", "minimum": 1, "maximum": 3, "description": "1=highest conviction (up to 12%), 2=high (up to 8%), 3=exploratory (up to 4%)" },
        "position_size_pct_portfolio": { "type": "number", "minimum": 0, "maximum": 0.20 },
        "position_size_rationale": { "type": "string" }
      }
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "description": "Each assumption must be binary pass/fail from a specific data source. No vague statements.",
      "items": {
        "type": "object",
        "required": ["id", "statement", "measurability", "monitoring_source", "check_frequency"],
        "properties": {
          "id": { "type": "string", "pattern": "^asm_[0-9]{2}$" },
          "statement": { "type": "string" },
          "measurability": {
            "type": "string",
            "description": "Specific data source + threshold + falsification criterion. Rejected if vague."
          },
          "monitoring_source": {
            "type": "string",
            "enum": ["news_llm", "market_data", "earnings_data", "flow_data", "cot_data", "macro_data", "user_manual"]
          },
          "check_frequency": { "type": "string", "enum": ["daily", "weekly", "monthly", "quarterly", "on_event"] },
          "current_status": { "type": "string", "enum": ["unverified", "validated", "invalidated", "monitoring"] }
        }
      }
    },
    "invalidation_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "condition", "severity", "source"],
        "properties": {
          "id": { "type": "string", "pattern": "^inv_[0-9]{2}$" },
          "condition": {
            "type": "string",
            "description": "Specific, measurable. Not 'market deteriorates'. Must be checkable."
          },
          "severity": {
            "type": "string",
            "enum": ["full_exit", "review_and_reduce", "flag_for_review"]
          },
          "source": {
            "type": "string",
            "enum": ["news_llm", "market_data", "flow_data", "cot_data", "macro_data", "user_manual"]
          },
          "triggered": { "type": "boolean", "default": false },
          "triggered_at": { "type": ["string", "null"], "format": "date-time" },
          "stop_price_level": {
            "type": ["number", "null"],
            "description": "Machine-readable price level for this condition. Set for price-based invalidations (e.g. copper < $11,000, ETF < €10.00). null for non-price conditions. Used by invalidation_watcher.py for automated monitoring without text parsing."
          },
          "stop_price_ticker": {
            "type": ["string", "null"],
            "description": "Ticker to check against stop_price_level (e.g. 'COPPER_LME', 'COPX.L', 'IQQH.DE'). Required when stop_price_level is set."
          }
        }
      }
    },
    "time_horizon": {
      "type": "object",
      "required": ["min_weeks", "expected_weeks", "max_weeks"],
      "properties": {
        "min_weeks": { "type": "integer" },
        "expected_weeks": { "type": "integer" },
        "max_weeks": { "type": "integer" },
        "catalyst_maturation_note": { "type": "string" },
        "review_dates": { "type": "array", "items": { "type": "string", "format": "date" } }
      }
    },
    "tax": {
      "type": "object",
      "required": ["entry_tax_year", "ytd_realized_gains_eur_at_entry", "marginal_bracket_at_entry"],
      "properties": {
        "entry_tax_year": { "type": "integer" },
        "ytd_realized_gains_eur_at_entry": { "type": "number" },
        "marginal_bracket_at_entry": {
          "type": "number",
          "enum": [0.19, 0.21, 0.23, 0.27],
          "description": "Spanish CGT marginal rate at entry, given YTD realized gains."
        },
        "estimated_tax_on_full_exit_if_50pct_gain": { "type": ["number", "null"] },
        "tax_notes": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["author"],
      "properties": {
        "author": { "type": "string" },
        "sector_snapshot_composite_at_entry": { "type": ["number", "null"] },
        "catalyst_strength_at_entry": { "type": ["number", "null"] },
        "prior_hit_rate_catalyst_sector": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "prior_n_trials": { "type": ["integer", "null"] },
        "confidence_override": { "type": ["number", "null"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "correlation_check": {
          "type": "object",
          "description": "Populated by /catalyx-thesis draft. Documents shared catalysts with open/draft theses and confirms allocation ceiling compliance.",
          "properties": {
            "correlated_open_theses": { "type": "array", "items": { "type": "string" }, "description": "thesis IDs sharing a primary structural catalyst" },
            "shared_catalysts": { "type": "array", "items": { "type": "string" }, "description": "struct_* IDs shared across correlated theses" },
            "combined_allocation_pct": { "type": "number", "description": "sum of position_size_pct_portfolio across all correlated theses including this one" },
            "combined_at_tier_ceiling": { "type": "boolean", "description": "true if combined_allocation_pct >= tier ceiling" },
            "correlation_note": { "type": "string" }
          },
          "required": ["correlated_open_theses", "shared_catalysts", "combined_allocation_pct", "combined_at_tier_ceiling", "correlation_note"]
        }
      }
    }
  },
  "additionalProperties": false
}
