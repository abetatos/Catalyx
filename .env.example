# CATALYX Environment Variables
# Copy to .env and fill in values. Never commit .env.
#
# CATALYX runs as a skill on the Claude Code session — there is no self-hosted LLM
# (no API keys) and no database (no DB URL). Persistence is files (Tier 1) + the
# parquet lake (Tier 2). This file is effectively empty by design.

# Optional: data path override (default: ./data)
# CATALYX_DATA_DIR=./data
